generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEKNISI
  MAGANG
}

enum UnitStatus {
  VERIFIED
  VERIFIED_WITH_NOTES
  RECHECK
  CANDIDATE_RETUR
}

enum QcResult {
  OK
  NOTES
  FAIL
}

enum DailyStatus {
  LOLOS
  LOLOS_DENGAN_CATATAN
  TIDAK_LOLOS
}

enum PaymentStatus {
  BELUM_JATUH_TEMPO
  MENDEKATI_TEMPO
  BUTUH_FOLLOW_UP
  LUNAS
}

enum AiLogStatus {
  OPEN
  DONE
}

enum CatalogSyncStatus {
  DRAFT
  READY
  SYNCED
  FAILED
}

enum SaleLocation {
  WIRADESA
  KAJEN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  username  String?  @unique
  password  String?
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qcAwal    QcAwal[]
  qcHarian  QcHarian[]
  attendance Attendance[]
}

model Attendance {
  id          String   @id @default(cuid())
  userId      String
  tanggal     DateTime @default(now())
  checkInAt   DateTime @default(now())
  checkOutAt  DateTime?
  status      String   @default("HADIR")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model BatchPSI {
  id               String        @id @default(cuid())
  nomorBatch       String        @unique
  supplier         String
  tanggalMasuk     DateTime
  tanggalTempo     DateTime
  statusPembayaran PaymentStatus @default(BELUM_JATUH_TEMPO)
  catatan          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  units Unit[]
}

model Unit {
  id                   String     @id @default(cuid())
  nomorUnit            String
  batchId              String
  supplier             String
  model                String
  processor            String
  ram                  String
  ssd                  String
  ssdSerial            String?
  lcdSize              String?
  lcdResolution        String?
  isTouchscreen        Boolean    @default(false)
  entryNotes           String?
  hargaModal           Int
  hargaJualRekomendasi Int
  stockLocation        SaleLocation @default(WIRADESA)
  batteryHealth        Int?
  ssdHealth            Int?
  statusObservasi      UnitStatus @default(RECHECK)
  tanggalMasuk         DateTime
  tempo                DateTime?
  catalogLiveUrl       String?
  catalogImageUrl      String?
  soldAt               DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  batch       BatchPSI      @relation(fields: [batchId], references: [id])
  qcAwal      QcAwal?
  qcHarian    QcHarian[]
  aiLogs      AiLog[]
  catalogSync CatalogSync[]
  sales       Sale[]

  @@unique([batchId, nomorUnit])
}

model QcAwal {
  id              String     @id @default(cuid())
  unitId          String     @unique
  checkerId       String
  tanggal         DateTime
  status          UnitStatus

  body            QcResult
  bodyBroken      QcResult
  karetBawah      QcResult
  repaint         QcResult
  layar           QcResult
  ukuranLcd       QcResult
  resolusiLayar   QcResult
  touchscreen     QcResult
  keyboard        QcResult
  touchpad        QcResult
  trackpoint      QcResult
  usb             QcResult
  kamera          QcResult
  port            QcResult
  speaker         QcResult
  mic             QcResult
  charger         QcResult
  battery         QcResult
  ssd             QcResult
  seriSsd         QcResult

  osInstalled     QcResult
  windowsVersion  String     @default("Windows 11")
  updateOs        QcResult
  driver          QcResult
  securityPatch   QcResult
  aplikasiDefault QcResult

  reminder        String[]
  catatan         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  unit            Unit       @relation(fields: [unitId], references: [id])
  checker         User       @relation(fields: [checkerId], references: [id])
}

model QcHarian {
  id              String      @id @default(cuid())
  unitId          String
  checkerId       String
  tanggal         DateTime
  ssdHealth       Int
  batteryHealth   Int
  ssdSerial       String?
  screenCondition String      @default("Normal")
  windowsVersion  String      @default("Windows 10")
  driverStatus    String      @default("OK")
  clockStatus     String      @default("OK")
  appStatus       String      @default("OK")
  officeStatus    String      @default("Tidak dicek")
  partitionCount  Int         @default(1)
  nyalaNormal     Boolean
  booting         Boolean
  layar           Boolean
  keyboard        Boolean
  ssd             Boolean
  battery         Boolean
  port            Boolean
  usb             Boolean     @default(true)
  camera          Boolean     @default(true)
  touchpad        Boolean     @default(true)
  trackpoint      Boolean     @default(true)
  bodyBroken      Boolean     @default(false)
  karetBawah      Boolean     @default(true)
  paintCondition  String?
  speaker         Boolean     @default(true)
  mic             Boolean     @default(true)
  wifi            Boolean
  bluetooth       Boolean
  kondisiHariIni  String
  masihLolos      DailyStatus
  catatan         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  unit            Unit        @relation(fields: [unitId], references: [id])
  checker         User        @relation(fields: [checkerId], references: [id])
}

model Sale {
  id            String       @id @default(cuid())
  unitId        String
  invoiceNumber String       @unique
  location      SaleLocation
  soldPrice     Int
  costPrice     Int
  subtotal      Int          @default(0)
  grossProfit   Int
  paymentMethod String
  buyerName     String?
  buyerPhone    String?
  buyerAddress  String?
  warrantySoftware String    @default("3 bulan")
  warrantyHardware String    @default("3 minggu")
  soldAt        DateTime     @default(now())
  voidedAt      DateTime?
  voidReason    String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  unit          Unit         @relation(fields: [unitId], references: [id])
  items         SaleItem[]
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  name        String
  category    String
  qty         Int      @default(1)
  unitPrice   Int
  unitCost    Int      @default(0)
  lineTotal   Int
  lineCost    Int      @default(0)
  createdAt   DateTime @default(now())

  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model AiLog {
  id          String      @id @default(cuid())
  unitId      String
  tanggal     DateTime    @default(now())
  rekomendasi String
  status      AiLogStatus @default(OPEN)
  source      String      @default("core-ai")
  createdAt   DateTime    @default(now())

  unit        Unit        @relation(fields: [unitId], references: [id])
}

model CatalogSync {
  id          String            @id @default(cuid())
  unitId      String
  status      CatalogSyncStatus @default(DRAFT)
  catalogUrl  String?
  lastSyncedAt DateTime?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  unit        Unit              @relation(fields: [unitId], references: [id])
}
